# ─────────────────────────────────────────────
# STRAVA
# ─────────────────────────────────────────────
# From your Strava API app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Your personal refresh token (obtained via OAuth — see README)
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# A secret string YOU invent — you'll use it during webhook registration
STRAVA_VERIFY_TOKEN=my_secret_verify_token

# ─────────────────────────────────────────────
# BLUESKY
# ─────────────────────────────────────────────
# Your Bluesky handle, e.g.: yourname.bsky.social
BLUESKY_HANDLE=yourname.bsky.social

# An App Password from https://bsky.app/settings/app-passwords
# (NOT your main account password)
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=5000
